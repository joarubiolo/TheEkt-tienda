{
  "version": 2,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.{js,ts}",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/create-order",
      "methods": ["POST"],
      "dest": "/api/create-order.ts"
    },
    {
      "src": "/api/webhook",
      "methods": ["POST"],
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/create-stock-notification",
      "methods": ["POST"],
      "dest": "/api/create-stock-notification.ts"
    },
    {
      "src": "/api/update-payment-id",
      "methods": ["POST"],
      "dest": "/api/update-payment-id.ts"
    },
    {
      "src": "/api/stock-notification",
      "methods": ["POST"],
      "dest": "/api/stock-notification.ts"
    },
    {
      "src": "/api/contact",
      "methods": ["POST"],
      "dest": "/api/contact.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/[^.]+",
      "dest": "/",
      "status": 200
    }
  ]
}
